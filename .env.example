# Football AI Platform - Environment Variables
# 复制为 .env 并填写实际值

# LLM - Gemini (默认)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# LLM - OpenAI (备选)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# App
FOOTBALL_APP_NAME=Football AI Platform
FOOTBALL_DEBUG=false
FOOTBALL_LOG_LEVEL=INFO

# HTTP
FOOTBALL_HTTP_TIMEOUT=30
FOOTBALL_HTTP_MAX_RETRIES=3

# Database
FOOTBALL_DB_PATH=data/football.db

# Analysis weights
FOOTBALL_WEIGHT_FORM=0.25
FOOTBALL_WEIGHT_HEAD_TO_HEAD=0.20
FOOTBALL_WEIGHT_HOME_AWAY=0.15
FOOTBALL_WEIGHT_INJURY=0.15
FOOTBALL_WEIGHT_TACTICS=0.25
FOOTBALL_CONFIDENCE_HIGH=0.75
FOOTBALL_CONFIDENCE_MEDIUM=0.55
